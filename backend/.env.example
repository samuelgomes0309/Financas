# ============================================
# CONFIGURAÇÃO DO BANCO DE DADOS
# ============================================
# String de conexão com o banco de dados PostgreSQL
# Formato: postgresql://USUÁRIO:SENHA@HOST:PORTA/NOME_DO_BANCO?schema=public
# 
# Exemplo:
# DATABASE_URL="postgresql://postgres:suasenha@localhost:5432/finance?schema=public"
#
# Observações:
# - Caracteres especiais na senha devem ser URL-encoded (ex: # = %23, @ = %40)
# - A porta padrão do PostgreSQL é 5432
# - O schema padrão é "public"
DATABASE_URL="postgresql://postgres:senha@localhost:5432/finance?schema=public"

# ============================================
# AUTENTICAÇÃO JWT
# ============================================
# Chave secreta para assinatura e verificação dos tokens JWT
# Use uma string aleatória e complexa em produção
# 
# Para gerar uma chave segura, você pode usar:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Observação: NUNCA compartilhe esta chave ou faça commit dela no repositório
JWT_SECRET="sua_chave_secreta_aqui_substitua_por_uma_chave_forte"

# ============================================
# CONFIGURAÇÃO DO SERVIDOR
# ============================================
# Porta em que o servidor Express irá rodar
# Padrão: 3333
PORT=3333